          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "rawSql": "\n                            SELECT \n                                project_number as \"Project\",\n                                MIN(work_date) as \"Start Date\",\n                                MAX(work_date) as \"End Date\",\n                                MAX(work_date) - MIN(work_date) + 1 as \"Duration (Days)\",\n                                ROUND(SUM(duration)::numeric, 2) as \"Total Hours\",\n                                COUNT(DISTINCT employee_name) as \"Team Size\"\n                            FROM work_logs\n                            WHERE \n                                work_date::timestamp >= $__timeFrom() \n                                AND work_date::timestamp <= $__timeTo()\n                                AND department IN (${department:sqlstring})\n                            GROUP BY project_number\n                            ORDER BY \"Duration (Days)\" DESC\n                        ",
          "refId": "A"
        }
      ],
      "title": "Project Duration & Metrics",
      "type": "table"
    }
