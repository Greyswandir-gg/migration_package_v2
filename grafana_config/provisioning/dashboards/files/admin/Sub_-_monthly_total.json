        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "rawSql": "\n            SELECT\n                employee_name as \"Employee\",\n                month_name as \"Month\",\n                ROUND(SUM(CASE WHEN year = 2023 THEN total_hours ELSE 0 END)::numeric, 2) as \"2023\",\n                ROUND(SUM(CASE WHEN year = 2024 THEN total_hours ELSE 0 END)::numeric, 2) as \"2024\",\n                ROUND(SUM(CASE WHEN year = 2025 THEN total_hours ELSE 0 END)::numeric, 2) as \"2025\",\n                ROUND(SUM(CASE WHEN year = 2026 THEN total_hours ELSE 0 END)::numeric, 2) as \"2026\"\n            FROM vw_sub_monthly_total\n            WHERE ('${year:raw}' = '$__all' OR year::text = ANY(ARRAY[${year:sqlstring}]::text[]))\n              AND ('${service:raw}' = '$__all' OR service = ANY(ARRAY[${service:sqlstring}]::text[]))\n              AND ('${employee:raw}' = '$__all' OR employee_name = ANY(ARRAY[${employee:sqlstring}]::text[]))\n            GROUP BY employee_name, month_name, month_num\n            ORDER BY employee_name, month_num\n        ",
          "refId": "A"
        }
      ],
      "title": "Subcontractor Hours by Year",
      "type": "table"
    },
