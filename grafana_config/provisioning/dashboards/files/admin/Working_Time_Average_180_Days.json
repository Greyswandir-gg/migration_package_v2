          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "rawSql": "SELECT\n  mitarbeiter AS \"Employee\",\n  bereich_neu AS \"Service bereich_neu\",\n  ma_kat AS \"Status\",\n  ROUND(SUM(dauer)::numeric, 2) AS \"total\",\n  ROUND((SUM(dauer) / 6.0)::numeric, 2) AS \"Average per 6 Month\"\nFROM xl_projecttimes\nWHERE datum::timestamp >= $__timeFrom()\n  AND datum::timestamp <= $__timeTo()\n  AND ('${service:raw}' = '$__all' OR bereich_neu IN (${service:sqlstring}))\n  AND ('${activity:raw}' = '$__all' OR task_new IN (${activity:sqlstring}))\n  AND ('${employee:raw}' = '$__all' OR mitarbeiter IN (${employee:sqlstring}))\n  AND ma_kat IS NOT NULL\n  AND ('${ma_kat:raw}' = '$__all' OR ma_kat IN (${ma_kat:sqlstring}))\nGROUP BY mitarbeiter, bereich_neu, ma_kat\nORDER BY \"Average per 6 Month\" DESC",
          "refId": "A"
        }
      ],
      "title": "working time average - 180 days",
      "type": "table"
    }
  ],
